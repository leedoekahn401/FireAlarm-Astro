---
import { authClient } from "../../lib/auth-client";
---

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; font-family: sans-serif; background: #f8f9fa;">
    <div style="padding: 2rem; background: white; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); text-align: center; max-width: 400px; width: 90%;">
        <h1 style="margin-bottom: 0.5rem; color: #1a73e8;">Fire Alarm</h1>
        <p style="margin-bottom: 2rem; color: #5f6368;">Sign in to manage your alarm system</p>
        
        <button 
            id="google-signin"
            style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; padding: 0.75rem; background-color: #ffffff; color: #3c4043; border: 1px solid #dadce0; border-radius: 4px; cursor: pointer; font-size: 1rem; font-weight: 500; transition: background-color 0.2s;"
            onmouseover="this.style.backgroundColor='#f7f8f8'"
            onmouseout="this.style.backgroundColor='#ffffff'"
        >
            <svg width="18" height="18" viewBox="0 0 18 18"><path d="M17.64 8.86c0-.61-.06-1.2-.16-1.76H9v3.34h4.84c-.21 1.12-.84 2.07-1.79 2.71v2.25h2.91c1.71-1.58 2.68-3.91 2.68-6.54z" fill="#4285F4"/><path d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.91-2.25c-.81.54-1.85.87-3.05.87-2.34 0-4.33-1.58-5.04-3.71H.92v2.33C2.4 16.14 5.48 18 9 18z" fill="#34A853"/><path d="M3.96 10.73A4.808 4.808 0 013.75 9c0-.6.1-1.19.21-1.73V4.94H.92A8.998 8.998 0 000 9c0 1.45.35 2.82.92 4.06l3.04-2.33z" fill="#FBBC05"/><path d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.47.89 11.43 0 9 0 5.48 0 2.4 1.86.92 4.94L3.96 7.27C4.67 5.14 6.66 3.58 9 3.58z" fill="#EA4335"/></svg>
            Sign in with Google
        </button>
    </div>
</div>

<script>
    import { authClient } from "../../lib/auth-client";

    const button = document.getElementById("google-signin");
    button?.addEventListener("click", async () => {
        try {
            await authClient.signIn.social({
                provider: "google",
                callbackURL: "/home",
            });
        } catch (error) {
            console.error("Sign-in error:", error);
            alert("Failed to sign in. Check console for details.");
        }
    });
</script>
